{
  "compilerOptions": {
    "target": "ES2022",                // Obsidian runs on modern Chromium; ES2022 is perfectly supported
    "module": "ESNext",
    "moduleResolution": "bundler",     // Matches what Esbuild/Vite uses to bundle your plugin
    "lib": ["DOM", "ES2022"],          // Access to both modern browser APIs and modern JS features
    
    "strict": true,                    // Keeps your code robust and prevents runtime plugin crashes
    "noUncheckedIndexedAccess": true,  // Keeps your precise array security for data processing
    
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,              // Prevents TypeScript from complaining about Obsidian's internal type files
    "isolatedModules": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
